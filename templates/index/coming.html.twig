{% extends 'base.html.twig' %}

{% block title %}Ginko art tattoo{% endblock %}

{% block body %}
    <div class="comming section-padding">
		<div class="v-middle">
			<div class="container">
				<div class="row text-center mb-20">
					<div class="col-md-12">
						<img src="{{ asset('img/logo-light.png') }}" style="width: 200px;" class="logo-img" alt="">
					</div>
					<div class="col-md-12">
						<h1>On arrive bientôt !</h1>
						<p>Notre nouveau site est en construction !</p>
					</div>
				</div>
				<div class="row text-center">
					<div class="col-6 offset-md-2 col-md-2">
						<div class="item">
							<div class="down">
								<h3 id="days">00</h3>
							</div>
							<div class="item-info">
								<h6>Jours</h6>
							</div>
						</div>
					</div>
					<div class="col-6 col-md-2">
						<div class="item">
							<div class="down">
								<h3 id="hours">00</h3>
							</div>
							<div class="item-info">
								<h6>Heures</h6>
							</div>
						</div>
					</div>
					<div class="col-6 col-md-2">
						<div class="item">
							<div class="down">
								<h3 id="minutes">00</h3>
							</div>
							<div class="item-info">
								<h6>Minutes</h6>
							</div>
						</div>
					</div>
					<div class="col-6 col-md-2">
						<div class="item">
							<div class="down">
								<h3 id="seconds">00</h3>
							</div>
							<div class="item-info">
								<h6>Secondes</h6>
							</div>
						</div>
					</div>
				</div>
				<div class="row text-center">
					<div class="offset-md-3 col-md-6">
						<p>Enregistrez-vous pour recevoir un mail le jour du lancement du site !</p>
						<form>
							<input type="email" name="email" placeholder="Email">
							<button>Inscription</button>
						</form>
					</div>
				</div>
				{# <div class="row text-center">
					<div class="go-back col-md-12">
						<a href='index.html'> <span><i class="ti-arrow-left" aria-hidden="true"></i></span>&nbsp; Back To Home </a>
					</div>
				</div> #}
			</div>
		</div>
	</div>

	<script src="js/jquery-3.6.3.min.js"></script>
	<script src="js/jquery-migrate-3.0.0.min.js"></script>
	<script src="js/bootstrap.min.js"></script>
	<script src="js/validator.js"></script>
	<script>
		document.addEventListener("DOMContentLoaded", function () {

			const eventDate = new Date(2026, 3, 1, 0, 0, 0).getTime();
			// Mois = 11 car janvier = 0

			function countdown() {
				const now = new Date().getTime();
				const remTime = eventDate - now;

				if (remTime <= 0) {
					document.getElementById("days").textContent = 0;
					document.getElementById("hours").textContent = 0;
					document.getElementById("minutes").textContent = 0;
					document.getElementById("seconds").textContent = 0;
					return;
				}

				const days = Math.floor(remTime / (1000 * 60 * 60 * 24));
				const hours = Math.floor((remTime / (1000 * 60 * 60)) % 24);
				const minutes = Math.floor((remTime / (1000 * 60)) % 60);
				const seconds = Math.floor((remTime / 1000) % 60);

				document.getElementById("days").textContent = days;
				document.getElementById("hours").textContent = hours;
				document.getElementById("minutes").textContent = minutes;
				document.getElementById("seconds").textContent = seconds;
			}

			countdown();
			setInterval(countdown, 1000);
		});
	</script>
{% endblock %}
